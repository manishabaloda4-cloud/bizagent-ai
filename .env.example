# ============================================
# BizAgent AI — Environment Variables
# ============================================

# Fireworks AI (from AMD Hackathon — $50 free credits)
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Supabase (from GitHub Student Pack — free Pro tier)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# AMD Developer Cloud (from AMD ADP — $100 free credits)
AMD_CLOUD_ENDPOINT=your_amd_cloud_endpoint
AMD_CLOUD_API_KEY=your_amd_cloud_api_key

# Optional: Anthropic (GitHub Student Pack gives free credits)
ANTHROPIC_API_KEY=your_anthropic_api_key

# App Config
APP_NAME=BizAgent AI
APP_VERSION=1.0.0
DEBUG=false
PORT=8000
